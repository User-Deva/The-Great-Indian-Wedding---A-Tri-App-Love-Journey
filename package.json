{
  "name": "great-indian-wedding",
  "version": "1.0.0",
  "description": "A tri-app ecosystem for the complete Indian love journey",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm -r --parallel --filter './apps/*' run dev",
    "dev:rishta": "pnpm --filter rishta run dev",
    "dev:shaadi": "pnpm --filter shaadi-sajao run dev",
    "dev:jannat": "pnpm --filter jannat-safar run dev",
    "build": "pnpm -r --filter './apps/*' run build",
    "build:hub": "node scripts/build-hub.js",
    "lint": "pnpm -r run lint",
    "type-check": "pnpm -r run type-check",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "preview": "pnpm build:hub && npx serve dist",
    "ci": "pnpm type-check && pnpm lint && pnpm test:coverage && pnpm build"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "vitest": "^1.0.0",
    "@vitest/ui": "^1.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "@testing-library/react": "^14.1.0",
    "@testing-library/jest-dom": "^6.1.5",
    "jsdom": "^23.0.0",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "prettier": "^3.1.0"
  }
}
