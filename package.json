{
  "name": "great-indian-wedding",
  "version": "1.0.0",
  "description": "A tri-app ecosystem for the complete Indian love journey",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@8.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "type-check": "pnpm -r run type-check",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:performance": "lighthouse https://localhost:3001 https://localhost:3002 https://localhost:3003 --output=json",
    "audit:security": "pnpm -r audit --prod && npm audit --production",
    "analyze:bundle": "pnpm -r run analyze:bundle",
    "ci": "pnpm type-check && pnpm lint && pnpm test:coverage && pnpm build"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "vitest": "^1.0.0",
    "@vitest/ui": "^1.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "@playwright/test": "^1.40.0",
    "playwright": "^1.40.0",
    "@testing-library/react": "^14.1.0",
    "@testing-library/jest-dom": "^6.1.5",
    "jsdom": "^23.0.0",
    "happy-dom": "^12.10.3",
    "lighthouse": "^11.0.0",
    "@lighthouse-labs/cli": "^11.0.0",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "prettier": "^3.1.0",
    "bundle-analyzer": "^1.0.0"
  }
}
