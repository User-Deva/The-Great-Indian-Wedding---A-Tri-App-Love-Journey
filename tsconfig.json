{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@great-indian-wedding/theme-engine": ["packages/theme-engine/src"],
      "@great-indian-wedding/auth": ["packages/auth/src"],
      "@great-indian-wedding/ui": ["packages/ui/src"],
      "@great-indian-wedding/our-story": ["packages/our-story/src"]
    }
  },
  "include": ["packages", "apps"]
}
